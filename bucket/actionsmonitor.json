    "url": "https://github.com/summitnl/ActionsMonitor/releases/download/v2026.04.22/ActionsMonitor.exe",
    "hash": "463C4F1ECCE17F500340159842A3E334FE5B2634887E738671AD8D4C7014C45D",
    "bin": "ActionsMonitor.exe",
    "shortcuts": [
        ["ActionsMonitor.exe", "Actions Monitor"]
    ],
    "pre_install": [
        "if (-not (Test-Path \"$persist_dir\\config.yaml\")) { New-Item \"$persist_dir\\config.yaml\" -ItemType File -Force | Out-Null }",
        "if (-not (Test-Path \"$persist_dir\\state.json\")) { New-Item \"$persist_dir\\state.json\" -ItemType File -Force | Out-Null }"
    ],
    "post_install": [
        "if (-not (Get-Process ActionsMonitor -ErrorAction SilentlyContinue)) { Start-Process \"$dir\\ActionsMonitor.exe\" }"
    ],
    "persist": [
        "config.yaml",
        "state.json"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/summitnl/ActionsMonitor/releases/download/v$version/ActionsMonitor.exe"
    }
}
