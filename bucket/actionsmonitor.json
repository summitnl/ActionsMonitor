  "url": "https://github.com/WizX20/ActionsMonitor/releases/download/v2026.05.01/ActionsMonitor.exe",
  "hash": "828921B0C66DD60D5D4AE91AD8FB5F313EA9039E17862D1B6E63FAE4DC7B9B61",
  "bin": "ActionsMonitor.exe",
  "shortcuts": [
    [
      "ActionsMonitor.exe",
      "Actions Monitor"
    ]
  ],
  "pre_install": [
    "if (-not (Test-Path \"$persist_dir\\config.yaml\")) { New-Item \"$persist_dir\\config.yaml\" -ItemType File -Force | Out-Null }",
    "if (-not (Test-Path \"$persist_dir\\state.json\")) { Set-Content -Path \"$persist_dir\\state.json\" -Value '{}' -Encoding utf8 -NoNewline }"
  ],
  "post_install": [
    "if (-not (Get-Process ActionsMonitor -ErrorAction SilentlyContinue)) { Start-Process \"$dir\\ActionsMonitor.exe\" }"
  ],
  "persist": [
    "config.yaml",
    "state.json"
  ],
  "checkver": "github",
  "autoupdate": {
    "url": "https://github.com/WizX20/ActionsMonitor/releases/download/v$version/ActionsMonitor.zip",
    "extract_dir": "ActionsMonitor"
  }
}
