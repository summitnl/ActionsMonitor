  "url": "https://github.com/WizX20/ActionsMonitor/releases/download/v2026.04.29.2/ActionsMonitor.exe",
  "hash": "450C176DB9CED1E962F89D04ADEF0C1224856FE0C54438EBAF2F068BA121DBD9",
  "bin": "ActionsMonitor.exe",
  "shortcuts": [
    [
      "ActionsMonitor.exe",
      "Actions Monitor"
    ]
  ],
  "pre_install": [
    "if (-not (Test-Path \"$persist_dir\\config.yaml\")) { New-Item \"$persist_dir\\config.yaml\" -ItemType File -Force | Out-Null }",
    "if (-not (Test-Path \"$persist_dir\\state.json\")) { Set-Content -Path \"$persist_dir\\state.json\" -Value '{}' -Encoding utf8 -NoNewline }"
  ],
  "post_install": [
    "if (-not (Get-Process ActionsMonitor -ErrorAction SilentlyContinue)) { Start-Process \"$dir\\ActionsMonitor.exe\" }"
  ],
  "persist": [
    "config.yaml",
    "state.json"
  ],
  "checkver": "github",
  "autoupdate": {
    "url": "https://github.com/WizX20/ActionsMonitor/releases/download/v$version/ActionsMonitor.exe"
  }
}
